<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="tree_view_advanced_search.ListRenderer"
       t-inherit="web.ListRenderer"
       t-inherit-mode="extension">

        <xpath expr="//table/thead" position="inside">
            <tr class="o_advanced_filter_row">
                <t t-foreach="columns" t-as="column" t-key="column_index">
                    <th t-if="column.name" class="o_advanced_filter_cell">
                        <input type="text"
                               class="o_input o_advanced_filter_input"
                               t-att-data-column-name="column.name"
                               t-att-placeholder="column.string || column.name"
                               t-att-value="getAdvancedFilterValue(column.name)"
                               t-on-input="(ev) => this.onAdvancedFilterInput(column.name, ev)"
                               t-on-keydown="this.onAdvancedFilterKeydown"/>
                    </th>
                    <th t-else=""/>
                </t>
            </tr>
        </xpath>
    </t>
</templates>
