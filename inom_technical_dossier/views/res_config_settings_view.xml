<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_inherit_technical_dossier" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.technical.dossier</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Technical Dossier" name="technical_dossier_settings">
                    <block title="Technical Dossier PDF Files">
                        <setting string="First PDF (Cover Page)">
                            <field name="first_pdf" filename="first_pdf_filename"/>
                        </setting>
                        <setting string="Last PDF (Closing Page)">
                            <field name="last_pdf" filename="last_pdf_filename"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
