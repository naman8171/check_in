<odoo>
    <record id="view_import_line_wizard_form" model="ir.ui.view">
        <field name="name">import.line.wizard.form</field>
        <field name="model">import.line.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Lines">
                <group>
                    <field name="upload_file" filename="file_name"/>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_line_wizard" model="ir.actions.act_window">
        <field name="name">Import Lines</field>
        <field name="res_model">import.line.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
