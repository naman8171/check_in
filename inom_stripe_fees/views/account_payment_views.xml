<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_payment_form_fees" model="ir.ui.view">
        <field name="name">account.payment.form.inom.fees</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="after">
                <field name="base_amount" readonly="1" invisible="not extra_fees"/>
                <field name="extra_fees" readonly="1" invisible="not extra_fees"/>
            </xpath>
        </field>
    </record>

</odoo>
