<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_transaction_form_show_fees" model="ir.ui.view">
        <field name="name">payment.transaction.form.show.fees</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.view_payment_transaction_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[field[@name='amount']]/field[@name='amount']" position="after">
                <field name="fees" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
