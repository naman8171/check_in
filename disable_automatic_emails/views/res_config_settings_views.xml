<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_disable_automatic_emails" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.disable.automatic.emails</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Email Delivery" name="disable_automatic_emails" data-string="Email Delivery">
                    <block title="Default Odoo Emails" name="disable_automatic_emails_block">
                        <setting id="disable_automatic_emails_setting" help="Stop Odoo from creating and sending default outgoing emails such as password resets, template emails, and notifications.">
                            <field name="disable_automatic_emails"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
