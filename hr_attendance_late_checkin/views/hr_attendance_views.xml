<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_attendance_tree_late_color" model="ir.ui.view">
        <field name="name">hr.attendance.list.late.color</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-danger">late_check_in</attribute>
            </xpath>
            <xpath expr="//list/field[@name='worked_hours']" position="after">
                <field name="late_check_in" optional="hide" />
                <field name="late_minutes" optional="hide" />
            </xpath>
        </field>
    </record>
</odoo>