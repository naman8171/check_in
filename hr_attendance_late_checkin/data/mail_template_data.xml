<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="mail_template_late_check_in" model="mail.template">
        <field name="name">Late Check-in Alert</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>

        <field name="subject">Late Check-in Notice: {{ object.employee_id.name or 'Employee' }}</field>

        <field name="email_from">{{ user.email_formatted or 'noreply@company.com' }}</field>

        <field name="body_html" type="html"><![CDATA[
            <div style="font-family: Arial, sans-serif; font-size: 14px; line-height: 1.6;">
                <p>
                    Hello
                    <strong><t t-out="object.employee_id.parent_id.name or 'Manager'"/></strong>,
                </p>

                <p>
                    This is to inform you that
                    <strong><t t-out="object.employee_id.name or 'Employee'"/></strong>
                    has checked in late.
                </p>

                <p>
                    <strong>Attendance ID:</strong>
                    <t t-out="object.id"/><br/>

                    <strong>Employee:</strong>
                    <t t-out="object.employee_id.name or 'N/A'"/><br/>

                    <strong>Date:</strong>
                    <t t-out="format_datetime(object.check_in, dt_format='yyyy-MM-dd') if object.check_in else 'N/A'"/><br/>

                    <strong>Scheduled Office Time:</strong>
                    <t t-out="format_datetime(object.scheduled_start_time) if object.scheduled_start_time else 'N/A'"/><br/>

                    <strong>Actual Check-in Time:</strong>
                    <t t-out="format_datetime(object.check_in) if object.check_in else 'N/A'"/><br/>

                    <strong>Late By:</strong>
                    <t t-out="object.late_minutes or 0"/> minute(s)
                </p>

                <p>
                    Message: The employee checked in after office time and this record has been
                    automatically marked as <strong style="color: red;">Late</strong>.
                </p>

                <p>
                    Regards,<br/>
                    <strong>Attendance System</strong>
                </p>
            </div>
        ]]></field>

        <field name="auto_delete" eval="True"/>
    </record>
    </data>
</odoo>
