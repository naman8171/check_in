<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clone_record_search" model="ir.ui.view">
        <field name="name">clone.record.search</field>
        <field name="model">clone.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="subject"/>
                <field name="customer_name"/>
                <field name="customer_email"/>
                <field name="state"/>
                <field name="assigned_user_id"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Assigned" name="group_assigned" context="{'group_by':'assigned_user_id'}"/>
                    <filter string="Category" name="group_category" context="{'group_by':'category'}"/>
                </group>
                <filter string="My Records" name="my_records" domain="[('assigned_user_id','=',uid)]"/>
                <filter string="Open" name="open" domain="[('state','in',('draft','in_progress','waiting'))]"/>
            </search>
        </field>
    </record>

    <record id="view_clone_record_tree" model="ir.ui.view">
        <field name="name">clone.record.tree</field>
        <field name="model">clone.record</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="subject"/>
                <field name="customer_name"/>
                <field name="category"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
                <field name="assigned_user_id"/>
                <field name="due_date"/>
            </tree>
        </field>
    </record>

    <record id="view_clone_record_kanban" model="ir.ui.view">
        <field name="name">clone.record.kanban</field>
        <field name="model">clone.record</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="subject"/>
                <field name="customer_name"/>
                <field name="priority"/>
                <field name="category"/>
                <field name="assigned_user_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="fw-bold"><field name="name"/></div>
                            <div><field name="subject"/></div>
                            <div class="text-muted"><field name="customer_name"/></div>
                            <div class="d-flex justify-content-between mt-2">
                                <field name="priority" widget="priority"/>
                                <field name="assigned_user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_clone_record_graph" model="ir.ui.view">
        <field name="name">clone.record.graph</field>
        <field name="model">clone.record</field>
        <field name="arch" type="xml">
            <graph string="Records Analytics" type="bar">
                <field name="state"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_clone_record_pivot" model="ir.ui.view">
        <field name="name">clone.record.pivot</field>
        <field name="model">clone.record</field>
        <field name="arch" type="xml">
            <pivot string="Records Pivot">
                <field name="state" type="row"/>
                <field name="category" type="col"/>
                <field name="id" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_clone_record_form" model="ir.ui.view">
        <field name="name">clone.record.form</field>
        <field name="model">clone.record</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Start" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_wait" type="object" string="Set Waiting" invisible="state not in ('in_progress','draft')"/>
                    <button name="action_done" type="object" string="Mark Done" class="btn-success" invisible="state in ('done','cancel')"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state in ('done','cancel')"/>
                    <button name="action_reset_draft" type="object" string="Reset" invisible="state == 'draft'"/>
                    <button name="action_send_summary_email" type="object" string="Send Email" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,waiting,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_send_summary_email" class="oe_stat_button" icon="fa-envelope">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Email</span>
                            </div>
                        </button>
                        <button type="action" name="%(action_clone_record)d" class="oe_stat_button" icon="fa-list">
                            <field name="line_count" string="Checklist" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="subject"/>
                            <field name="customer_name"/>
                            <field name="customer_email"/>
                            <field name="customer_phone"/>
                            <field name="company"/>
                        </group>
                        <group>
                            <field name="assigned_user_id"/>
                            <field name="category"/>
                            <field name="priority" widget="priority"/>
                            <field name="due_date"/>
                            <field name="close_date" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Checklist">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="is_done"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Internal Note">
                            <field name="internal_note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_clone_record" model="ir.actions.act_window">
        <field name="name">Cloned Dashboard</field>
        <field name="res_model">clone.record</field>
        <field name="view_mode">kanban,tree,form,graph,pivot</field>
        <field name="search_view_id" ref="view_clone_record_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first cloned record.</p>
        </field>
    </record>
</odoo>
