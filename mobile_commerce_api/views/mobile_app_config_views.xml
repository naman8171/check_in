<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_app_config_tree" model="ir.ui.view">
        <field name="name">mobile.app.config.list</field>
        <field name="model">mobile.app.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="website_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="currency_id"/>
                <field name="active"/>
                <field name="maintenance_mode"/>
            </list>
        </field>
    </record>
    <record id="view_mobile_app_config_form" model="ir.ui.view">
        <field name="name">mobile.app.config.form</field>
        <field name="model">mobile.app.config</field>
        <field name="arch" type="xml">
            <form>
                <header><button name="action_open_api_logs" type="object" string="API Logs" class="btn-secondary"/></header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="website_id"/>
                            <field name="language_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="logo" widget="image"/>
                            <field name="splash_screen" widget="image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Theme"><group><field name="primary_color" widget="color"/><field name="secondary_color" widget="color"/><field name="accent_color" widget="color"/></group></page>
                        <page string="Firebase"><group><field name="firebase_project_id"/><field name="firebase_sender_id"/><field name="firebase_server_key" password="True"/><field name="firebase_service_account_json"/></group></page>
                        <page string="API &amp; Security"><group><field name="jwt_secret" password="True"/><field name="jwt_expiry_minutes"/><field name="api_rate_limit"/><field name="maintenance_mode"/><field name="maintenance_message"/></group><field name="api_key_ids"/></page>
                        <page string="Features"><group><field name="allow_guest_checkout"/><field name="enable_push_notifications"/><field name="enable_product_reviews"/><field name="enable_product_comparison"/><field name="enable_wishlist"/></group></page>
                        <page string="Support"><group><field name="terms_url"/><field name="privacy_url"/><field name="support_email"/><field name="support_phone"/></group></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_mobile_app_config_search" model="ir.ui.view"><field name="name">mobile.app.config.search</field><field name="model">mobile.app.config</field><field name="arch" type="xml"><search><field name="name"/><field name="website_id"/><filter name="active" string="Active" domain="[('active','=',True)]"/><group expand="0" string="Group By"><filter name="company" string="Company" context="{'group_by':'company_id'}"/><filter name="website" string="Website" context="{'group_by':'website_id'}"/></group></search></field></record>
    <record id="action_mobile_app_config" model="ir.actions.act_window"><field name="name">Mobile App Settings</field><field name="res_model">mobile.app.config</field><field name="view_mode">list,form</field></record>
</odoo>
