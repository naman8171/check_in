<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_product_review_tree" model="ir.ui.view"><field name="name">mobile.product.review.list</field><field name="model">mobile.product.review</field><field name="arch" type="xml"><list><field name="name"/><field name="product_tmpl_id"/><field name="partner_id"/><field name="rating"/><field name="state" widget="badge"/><field name="website_id"/></list></field></record>
    <record id="view_mobile_product_review_form" model="ir.ui.view"><field name="name">mobile.product.review.form</field><field name="model">mobile.product.review</field><field name="arch" type="xml"><form><header><button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state == 'approved'"/><button name="action_reject" type="object" string="Reject" invisible="state == 'rejected'"/><field name="state" widget="statusbar"/></header><sheet><group><field name="name"/><field name="active"/><field name="partner_id"/><field name="product_tmpl_id"/><field name="website_id"/><field name="company_id"/><field name="rating"/><field name="comment"/></group></sheet><chatter/></form></field></record>
    <record id="action_mobile_product_review" model="ir.actions.act_window"><field name="name">Product Reviews</field><field name="res_model">mobile.product.review</field><field name="view_mode">list,form</field></record>

    <record id="view_mobile_wishlist_tree" model="ir.ui.view"><field name="name">mobile.wishlist.list</field><field name="model">mobile.wishlist</field><field name="arch" type="xml"><list><field name="partner_id"/><field name="product_tmpl_id"/><field name="website_id"/><field name="company_id"/><field name="create_date"/></list></field></record>
    <record id="action_mobile_wishlist" model="ir.actions.act_window"><field name="name">Wishlists</field><field name="res_model">mobile.wishlist</field><field name="view_mode">list</field></record>

    <record id="view_mobile_product_comparison_tree" model="ir.ui.view"><field name="name">mobile.product.comparison.list</field><field name="model">mobile.product.comparison</field><field name="arch" type="xml"><list><field name="partner_id"/><field name="product_tmpl_id"/><field name="website_id"/><field name="company_id"/><field name="create_date"/></list></field></record>
    <record id="action_mobile_product_comparison" model="ir.actions.act_window"><field name="name">Product Comparisons</field><field name="res_model">mobile.product.comparison</field><field name="view_mode">list</field></record>
</odoo>
