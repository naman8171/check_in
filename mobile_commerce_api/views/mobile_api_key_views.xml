<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_api_key_tree" model="ir.ui.view"><field name="name">mobile.api.key.list</field><field name="model">mobile.api.key</field><field name="arch" type="xml"><list><field name="name"/><field name="app_config_id"/><field name="platform"/><field name="key_prefix"/><field name="last_used_at"/><field name="request_count"/><field name="active"/></list></field></record>
