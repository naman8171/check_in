<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_notification_tree" model="ir.ui.view"><field name="name">mobile.notification.list</field><field name="model">mobile.notification</field><field name="arch" type="xml"><list><field name="name"/><field name="app_config_id"/><field name="notification_type"/><field name="scheduled_at"/><field name="sent_at"/><field name="state" widget="badge"/><field name="success_count"/><field name="failure_count"/></list></field></record>
    <record id="view_mobile_notification_form" model="ir.ui.view"><field name="name">mobile.notification.form</field><field name="model">mobile.notification</field><field name="arch" type="xml"><form><header><button name="action_schedule" type="object" string="Schedule" class="btn-primary" invisible="state != 'draft'"/><button name="action_send_now" type="object" string="Send Now" class="btn-primary" invisible="state in ('sent','cancelled')"/><button name="action_cancel" type="object" string="Cancel" invisible="state in ('sent','cancelled')"/><field name="state" widget="statusbar"/></header><sheet><group><group><field name="name"/><field name="app_config_id"/><field name="notification_type"/><field name="title"/><field name="body"/><field name="scheduled_at"/></group><group><field name="image" widget="image"/><field name="target_url"/><field name="target_model"/><field name="target_res_id"/></group></group><notebook><page string="Audience"><field name="partner_ids" widget="many2many_tags"/><field name="device_ids"/></page><page string="Result"><group><field name="sent_at" readonly="1"/><field name="success_count" readonly="1"/><field name="failure_count" readonly="1"/><field name="error_message" readonly="1"/></group></page></notebook></sheet><chatter/></form></field></record>
    <record id="action_mobile_notification" model="ir.actions.act_window"><field name="name">Notifications</field><field name="res_model">mobile.notification</field><field name="view_mode">list,form</field></record>
</odoo>
