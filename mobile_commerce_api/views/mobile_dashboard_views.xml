<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_app_config_kanban_dashboard" model="ir.ui.view">
        <field name="name">mobile.app.config.kanban.dashboard</field>
        <field name="model">mobile.app.config</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard">
                <field name="name"/>
                <field name="website_id"/>
                <field name="company_id"/>
                <field name="maintenance_mode"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click p-3">
                            <div class="d-flex justify-content-between">
                                <strong><field name="name"/></strong>
                                <span t-if="record.maintenance_mode.raw_value" class="badge text-bg-warning">Maintenance</span>
                            </div>
                            <div class="text-muted mt-2"><field name="website_id"/></div>
                            <div class="text-muted"><field name="company_id"/></div>
                            <div class="mt-3">Manage app settings, API keys, devices, banners, notifications, and API telemetry.</div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_mobile_dashboard" model="ir.actions.act_window">
        <field name="name">Mobile Dashboard</field>
        <field name="res_model">mobile.app.config</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_mobile_app_config_kanban_dashboard"/>
    </record>
</odoo>
