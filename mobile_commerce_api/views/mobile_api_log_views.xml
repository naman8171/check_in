<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_api_log_tree" model="ir.ui.view"><field name="name">mobile.api.log.list</field><field name="model">mobile.api.log</field><field name="arch" type="xml"><list create="0" edit="0"><field name="create_date"/><field name="endpoint"/><field name="method"/><field name="status_code"/><field name="duration_ms"/><field name="user_id"/><field name="api_key_id"/><field name="ip_address"/></list></field></record>
    <record id="view_mobile_api_log_form" model="ir.ui.view"><field name="name">mobile.api.log.form</field><field name="model">mobile.api.log</field><field name="arch" type="xml"><form create="0" edit="0"><sheet><group><group><field name="app_config_id"/><field name="api_key_id"/><field name="user_id"/><field name="partner_id"/><field name="endpoint"/><field name="method"/></group><group><field name="status_code"/><field name="duration_ms"/><field name="ip_address"/><field name="company_id"/><field name="website_id"/></group></group><notebook><page string="Request"><field name="request_payload"/></page><page string="Response"><field name="response_payload"/></page><page string="Error"><field name="error_message"/></page></notebook></sheet></form></field></record>
    <record id="view_mobile_api_log_search" model="ir.ui.view"><field name="name">mobile.api.log.search</field><field name="model">mobile.api.log</field><field name="arch" type="xml"><search><field name="endpoint"/><field name="user_id"/><field name="api_key_id"/><filter name="errors" string="Errors" domain="[('status_code','&gt;=',400)]"/><group expand="0" string="Group By"><filter name="endpoint" string="Endpoint" context="{'group_by':'endpoint'}"/><filter name="status" string="Status" context="{'group_by':'status_code'}"/><filter name="day" string="Day" context="{'group_by':'create_date:day'}"/></group></search></field></record>
    <record id="view_mobile_api_log_pivot" model="ir.ui.view"><field name="name">mobile.api.log.pivot</field><field name="model">mobile.api.log</field><field name="arch" type="xml"><pivot><field name="endpoint" type="row"/><field name="status_code" type="col"/><field name="id" type="measure"/></pivot></field></record>
    <record id="view_mobile_api_log_graph" model="ir.ui.view"><field name="name">mobile.api.log.graph</field><field name="model">mobile.api.log</field><field name="arch" type="xml"><graph type="bar"><field name="endpoint"/><field name="id" type="measure"/></graph></field></record>
    <record id="action_mobile_api_log" model="ir.actions.act_window"><field name="name">API Logs</field><field name="res_model">mobile.api.log</field><field name="view_mode">list,form,pivot,graph</field></record>
</odoo>
