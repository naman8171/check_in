<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inom_stripe_fees_invoice" model="ir.ui.view">
        <field name="name">account.move.form.inom.stripe.fees.invoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_payment_term_id']" position="after">
                <field name="stripe_fee_estimated"
                       readonly="1"
                       invisible="move_type not in ('out_invoice', 'out_refund') or state != 'posted'"/>
                <field name="stripe_total_with_fee"
                       readonly="1"
                       invisible="move_type not in ('out_invoice', 'out_refund') or state != 'posted'"/>
                <field name="stripe_fee_paid"
                       readonly="1"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>
</odoo>
