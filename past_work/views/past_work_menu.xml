<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Top Level App Menu ───────────────────────── -->
    <menuitem
        id="menu_past_work_root"
        name="Past Work"
        sequence="95"
        web_icon="past_work,static/description/icon.png"
        groups="base.group_user"/>

    <!-- ─── Main Section ─────────────────────────────── -->
    <menuitem
        id="menu_past_work_main"
        name="Projects"
        parent="menu_past_work_root"
        sequence="10"/>

    <menuitem
        id="menu_past_work_all_projects"
        name="All Projects"
        parent="menu_past_work_main"
        action="action_past_work_project"
        sequence="10"/>

    <menuitem
        id="menu_past_work_published"
        name="Published"
        parent="menu_past_work_main"
        action="action_past_work_project_published"
        sequence="20"/>

    <!-- ─── Configuration ────────────────────────────── -->
    <menuitem
        id="menu_past_work_config"
        name="Configuration"
        parent="menu_past_work_root"
        sequence="90"
        groups="base.group_system"/>

    <menuitem
        id="menu_past_work_categories"
        name="Categories"
        parent="menu_past_work_config"
        action="action_past_work_category"
        sequence="10"
        groups="base.group_system"/>

    <menuitem
        id="menu_past_work_tags"
        name="Tags"
        parent="menu_past_work_config"
        action="action_past_work_tag"
        sequence="20"
        groups="base.group_system"/>

</odoo>
