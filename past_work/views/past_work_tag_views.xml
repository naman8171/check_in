<odoo>
    <record id="view_past_work_tag_tree" model="ir.ui.view">
        <field name="name">past.work.tag.tree</field>
        <field name="model">past.work.tag</field>
        <field name="arch" type="xml">
            <list string="Tags">
                <field name="name"/>            </list>
        </field>
    </record>

    <record id="view_past_work_tag_form" model="ir.ui.view">
        <field name="name">past.work.tag.form</field>
        <field name="model">past.work.tag</field>
        <field name="arch" type="xml">
            <form string="Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_past_work_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">past.work.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
