<odoo>
    <record id="view_past_work_category_tree" model="ir.ui.view">
        <field name="name">past.work.category.tree</field>
        <field name="model">past.work.category</field>
        <field name="arch" type="xml">
            <list string="Categories">
                <field name="name"/>            </list>
        </field>
    </record>

    <record id="view_past_work_category_form" model="ir.ui.view">
        <field name="name">past.work.category.form</field>
        <field name="model">past.work.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_past_work_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">past.work.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
