<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ══════════════════════════════════════════════════════════════
     WEBSITE NAVBAR MENU ITEM
     Adds "Past Work" to the site's top navigation bar
══════════════════════════════════════════════════════════════ -->

<record id="website_menu_past_work" model="website.menu">
    <field name="name">Past Work</field>
    <field name="url">/past-work</field>
    <field name="parent_id" ref="website.main_menu"/>
    <field name="sequence">60</field>
</record>

<!-- ══════════════════════════════════════════════════════════════
     PORTFOLIO INDEX PAGE  (/past-work)
══════════════════════════════════════════════════════════════ -->

<template id="past_work_index_template" name="Past Work - Portfolio">
    <t t-call="website.layout">

        <t t-set="additional_title">Past Work</t>
        <t t-set="head">
            <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800;900&amp;family=Quicksand:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
        </t>

        <div id="wrap" class="past-work-page">

            <section class="pw-landing-section">
                <div class="container">
                    <div class="pw-landing-grid">
                        <div class="pw-landing-content">
                            <span class="pw-landing-badge"><i class="bi bi-stars"></i> Featured Portfolio</span>
                            <h2 class="pw-landing-title">Designing impact-driven digital experiences.</h2>
                            <p class="pw-landing-subtitle">
                                Explore selected work across branding, product design, and web development where strategy,
                                creativity, and clean execution come together.
                            </p>
                            <div class="pw-landing-actions">
                                <a href="#pwGrid" class="pw-landing-btn pw-landing-btn-primary">
                                    Explore Projects <i class="bi bi-arrow-down-right"></i>
                                </a>
                                <a href="/contactus" class="pw-landing-btn pw-landing-btn-outline">
                                    Start a Project <i class="bi bi-lightning-charge"></i>
                                </a>
                            </div>
                        </div>
                        <div class="pw-landing-card">
                            <div class="pw-landing-stats">
                                <div class="pw-landing-stat">
                                    <strong>50+</strong>
                                    <span>Projects Delivered</span>
                                </div>
                                <div class="pw-landing-stat">
                                    <strong>12</strong>
                                    <span>Industry Verticals</span>
                                </div>
                                <div class="pw-landing-stat">
                                    <strong>95%</strong>
                                    <span>Client Satisfaction</span>
                                </div>
                                <div class="pw-landing-stat">
                                    <strong>24/7</strong>
                                    <span>Collaboration Support</span>
                                </div>
                            </div>
                            <p class="pw-landing-note">
                                Built with a focus on visual clarity, performance, and business outcomes.
                            </p>
                        </div>
                    </div>
                </div>
            </section>



            <section class="pw-about-section">
                <div class="container">
                    <div class="pw-section-heading">
                        <h2>About Our Work</h2>
                        <p>Hum business goals ko strong design thinking aur practical development ke saath combine karte hain, taaki har project sirf sundar na lage, balki measurable impact bhi de.</p>
                    </div>
                    <div class="pw-about-content">
                        <div class="pw-about-grid">
                            <p>
                                Har engagement me hamara focus clear rehta hai — user journey ko simple banana,
                                brand identity ko meaningful banana, aur performance ko fast rakhna.
                                Is approach ki wajah se hum long-term partnerships build karte hain.
                            </p>
                            <ul class="pw-about-list">
                                <li><i class="bi bi-check2-circle"></i> Discovery-led planning before execution</li>
                                <li><i class="bi bi-check2-circle"></i> Conversion-focused design decisions</li>
                                <li><i class="bi bi-check2-circle"></i> Clean code with scalable structure</li>
                                <li><i class="bi bi-check2-circle"></i> Transparent communication at every step</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>

            <section class="pw-services-section">
                <div class="container">
                    <div class="pw-section-heading">
                        <h2>What We Can Build</h2>
                        <p>End-to-end digital services jo aapke idea ko strategy se launch tak smoothly le jayein.</p>
                    </div>
                    <div class="pw-services-grid">
                        <article class="pw-service-card">
                            <span class="pw-service-icon"><i class="bi bi-palette"></i></span>
                            <h3>Brand &amp; UI Design</h3>
                            <p>Consistent visual systems, intuitive interfaces, aur premium brand presentation.</p>
                        </article>
                        <article class="pw-service-card">
                            <span class="pw-service-icon"><i class="bi bi-code-slash"></i></span>
                            <h3>Web Development</h3>
                            <p>Fast, secure, and maintainable websites tailored to real business workflows.</p>
                        </article>
                        <article class="pw-service-card">
                            <span class="pw-service-icon"><i class="bi bi-graph-up-arrow"></i></span>
                            <h3>Growth Optimization</h3>
                            <p>Performance tuning, conversion improvement, and analytics-backed iterations.</p>
                        </article>
                    </div>
                </div>
            </section>

            <section class="pw-process-section">
                <div class="container">
                    <div class="pw-section-heading">
                        <h2>How We Work</h2>
                        <p>Simple process, clear ownership, aur predictable delivery timeline.</p>
                    </div>
                    <div class="pw-process-grid">
                        <div class="pw-process-step">
                            <span class="pw-step-number">01</span>
                            <h4>Understand</h4>
                            <p>Business context, users, competitors, and target outcomes ko deeply map karna.</p>
                        </div>
                        <div class="pw-process-step">
                            <span class="pw-step-number">02</span>
                            <h4>Design &amp; Build</h4>
                            <p>Validated flows ke basis par UI, development, and content integration ko execute karna.</p>
                        </div>
                        <div class="pw-process-step">
                            <span class="pw-step-number">03</span>
                            <h4>Launch &amp; Improve</h4>
                            <p>Release ke baad performance review karna aur continuous improvements ship karna.</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="pw-contact-cta">
                <div class="container">
                    <div class="pw-contact-box">
                        <h2>Contact Us</h2>
                        <p>Agar aap apne next website, product, ya rebranding project par kaam start karna chahte hain, to humse connect karein. Hum aapko strategy se delivery tak guide karenge.</p>
                        <div class="pw-contact-actions">
                            <a class="pw-landing-btn pw-landing-btn-primary" href="/contactus">
                                Let&apos;s Talk <i class="bi bi-arrow-right"></i>
                            </a>
                            <a class="pw-contact-chip" href="mailto:hello@example.com">
                                <i class="bi bi-envelope"></i> hello@example.com
                            </a>
                        </div>
                    </div>
                </div>
            </section>
            <div class="pw-page-title">
                <div class="container">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house-door"></i></a></li>
                            <li class="breadcrumb-item active" aria-current="page">Past Work</li>
                        </ol>
                    </nav>
                    <div class="pw-title-wrapper">
                        <h1>Past Work</h1>
                        <p>A curated collection of projects — crafted with care and purpose.</p>
                    </div>
                </div>
            </div>

            <section class="pw-portfolio-section">
                <div class="container">

                    <div class="pw-filters-wrapper">
                        <ul class="pw-filters" id="pwFilters">
                            <li data-filter="*"
                                t-att-class="'pw-filter-btn' + (' active' if active_filter == '*' else '')">
                                All Projects
                            </li>
                            <t t-foreach="categories" t-as="cat">
                                <li t-att-data-filter="'.' + cat.slug"
                                    t-att-class="'pw-filter-btn' + (' active' if active_filter == cat.slug else '')">
                                    <t t-out="cat.name"/>
                                </li>
                            </t>
                        </ul>
                    </div>

                    <div class="row gy-4 pw-portfolio-grid" id="pwGrid">
                        <t t-foreach="projects" t-as="project">
                            <div t-att-class="'col-lg-4 col-md-6 pw-portfolio-item ' + (project.category_id.slug or '')">
                                <div class="pw-portfolio-card">
                                    <div class="pw-image-container">
                                        <t t-if="project.cover_image">
                                            <img t-att-src="'/web/image/past.work.project/%d/cover_image/600x400' % project.id"
                                                 class="img-fluid"
                                                 t-att-alt="project.name"
                                                 loading="lazy"/>
                                        </t>
                                        <t t-else="">
                                            <div class="pw-no-image"><i class="bi bi-image"></i></div>
                                        </t>
                                        <div class="pw-overlay">
                                            <div class="pw-overlay-content">
                                                <a t-att-href="'/past-work/' + (project.slug or str(project.id))"
                                                   class="pw-details-link"
                                                   t-att-title="project.name">
                                                    <i class="bi bi-arrow-right"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="pw-card-content">
                                        <span class="pw-category-label"><t t-out="project.category_id.name"/></span>
                                        <h3><t t-out="project.name"/></h3>
                                        <p t-if="project.subtitle"><t t-out="project.subtitle"/></p>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-if="not projects">
                            <div class="col-12 text-center py-5">
                                <i class="bi bi-folder2-open" style="font-size:3rem; opacity:0.3"></i>
                                <p class="mt-3 text-muted">No projects found. Check back soon!</p>
                            </div>
                        </t>
                    </div>

                </div>
            </section>

        </div>

    </t>
</template>

<!-- ══════════════════════════════════════════════════════════════
     PROJECT DETAIL PAGE  (/past-work/<slug>)
══════════════════════════════════════════════════════════════ -->

<template id="past_work_detail_template" name="Past Work - Project Detail">
    <t t-call="website.layout">

        <t t-set="additional_title" t-value="project.name"/>
        <t t-set="head">
            <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800;900&amp;family=Quicksand:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
        </t>

        <div id="wrap" class="past-work-page past-work-detail-page">

            <div class="pw-page-title">
                <div class="container">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house-door"></i></a></li>
                            <li class="breadcrumb-item"><a href="/past-work">Past Work</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><t t-out="project.name"/></li>
                        </ol>
                    </nav>
                </div>
            </div>

            <section class="pw-project-hero">
                <div class="container">
                    <div class="pw-hero-content">
                        <div class="pw-project-category"><t t-out="project.category_id.name"/></div>
                        <h1 class="pw-project-title"><t t-out="project.name"/></h1>
                        <p class="pw-project-subtitle" t-if="project.subtitle"><t t-out="project.subtitle"/></p>
                    </div>
                    <div class="pw-meta-grid" t-if="project.client_name or project.timeline or project.year or project.services">
                        <div class="pw-meta-col" t-if="project.client_name">
                            <div class="pw-meta-label">Client</div>
                            <div class="pw-meta-value"><t t-out="project.client_name"/></div>
                        </div>
                        <div class="pw-meta-col" t-if="project.timeline">
                            <div class="pw-meta-label">Timeline</div>
                            <div class="pw-meta-value"><t t-out="project.timeline"/></div>
                        </div>
                        <div class="pw-meta-col" t-if="project.year">
                            <div class="pw-meta-label">Year</div>
                            <div class="pw-meta-value"><t t-out="project.year"/></div>
                        </div>
                        <div class="pw-meta-col" t-if="project.services">
                            <div class="pw-meta-label">Services</div>
                            <div class="pw-meta-value"><t t-out="project.services"/></div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="pw-visual-showcase" t-if="project.cover_image or project.image_ids">
                <div class="container">
                    <div class="pw-main-visual">
                        <t t-if="project.image_ids">
                            <div class="pw-slider" id="pwSlider">
                                <div class="pw-slides">
                                    <t t-if="project.cover_image">
                                        <div class="pw-slide active">
                                            <img t-att-src="'/web/image/past.work.project/%d/cover_image/1200x700' % project.id"
                                                 class="img-fluid" t-att-alt="project.name"/>
                                        </div>
                                    </t>
                                    <t t-foreach="project.image_ids" t-as="img">
                                        <div class="pw-slide">
                                            <img t-att-src="'/web/image/past.work.image/%d/image/1200x700' % img.id"
                                                 class="img-fluid"
                                                 t-att-alt="img.caption or project.name"/>
                                        </div>
                                    </t>
                                </div>
                                <button class="pw-slider-btn pw-slider-prev" type="button" onclick="pwSliderPrev()">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <button class="pw-slider-btn pw-slider-next" type="button" onclick="pwSliderNext()">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </t>
                        <t t-elif="project.cover_image">
                            <img t-att-src="'/web/image/past.work.project/%d/cover_image/1200x700' % project.id"
                                 class="img-fluid pw-single-image" t-att-alt="project.name"/>
                        </t>
                    </div>
                </div>
            </section>

            <section class="pw-content-section">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-8 offset-lg-2">
                            <div class="pw-project-overview" t-if="project.description">
                                <h2>Project Overview</h2>
                                <div class="pw-overview-text"><t t-out="project.description"/></div>
                            </div>
                            <div class="pw-challenge-solution" t-if="project.challenge or project.approach">
                                <div class="pw-challenge-block" t-if="project.challenge">
                                    <h3>The Challenge</h3>
                                    <t t-out="project.challenge"/>
                                </div>
                                <div class="pw-solution-block" t-if="project.approach">
                                    <h3>Our Approach</h3>
                                    <t t-out="project.approach"/>
                                </div>
                            </div>
                            <div class="pw-tags" t-if="project.tag_ids">
                                <t t-foreach="project.tag_ids" t-as="tag">
                                    <span class="pw-tag"><t t-out="tag.name"/></span>
                                </t>
                            </div>
                            <div class="pw-project-url" t-if="project.project_url">
                                <a t-att-href="project.project_url" target="_blank" class="pw-btn-ghost">
                                    View Live Project <i class="bi bi-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="pw-related-section" t-if="related_projects">
                <div class="container">
                    <div class="pw-section-title">
                        <h2>More from <t t-out="project.category_id.name"/></h2>
                    </div>
                    <div class="row gy-4">
                        <t t-foreach="related_projects" t-as="rel">
                            <div class="col-lg-4 col-md-6">
                                <div class="pw-portfolio-card">
                                    <div class="pw-image-container">
                                        <t t-if="rel.cover_image">
                                            <img t-att-src="'/web/image/past.work.project/%d/cover_image/600x400' % rel.id"
                                                 class="img-fluid" t-att-alt="rel.name" loading="lazy"/>
                                        </t>
                                        <t t-else="">
                                            <div class="pw-no-image"><i class="bi bi-image"></i></div>
                                        </t>
                                        <div class="pw-overlay">
                                            <div class="pw-overlay-content">
                                                <a t-att-href="'/past-work/' + (rel.slug or str(rel.id))"
                                                   class="pw-details-link">
                                                    <i class="bi bi-arrow-right"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="pw-card-content">
                                        <span class="pw-category-label"><t t-out="rel.category_id.name"/></span>
                                        <h3><t t-out="rel.name"/></h3>
                                        <p t-if="rel.subtitle"><t t-out="rel.subtitle"/></p>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                    <div class="text-center mt-5">
                        <a href="/past-work" class="pw-btn-ghost">
                            View All Projects <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </section>

            <script type="text/javascript">
            (function(){
                var current = 0;
                function showSlide(n){
                    var slides = document.querySelectorAll('#pwSlider .pw-slide');
                    if(!slides.length) return;
                    current = (n + slides.length) % slides.length;
                    slides.forEach(function(s){ s.classList.remove('active'); });
                    slides[current].classList.add('active');
                }
                window.pwSliderNext = function(){ showSlide(current + 1); };
                window.pwSliderPrev = function(){ showSlide(current - 1); };
                setInterval(function(){ window.pwSliderNext(); }, 4000);
            })();
            </script>

        </div>

    </t>
</template>

</odoo>
