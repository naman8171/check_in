<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════
         CATEGORY VIEWS
    ═══════════════════════════════════════════ -->

    <record id="view_past_work_category_list" model="ir.ui.view">
        <field name="name">past.work.category.list</field>
        <field name="model">past.work.category</field>
        <field name="arch" type="xml">
            <list string="Categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="slug"/>
                <field name="project_count" string="Projects"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_past_work_category_form" model="ir.ui.view">
        <field name="name">past.work.category.form</field>
        <field name="model">past.work.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="slug"
                                   help="Used as the CSS class/filter slug, e.g. filter-branding"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_past_work_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">past.work.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No categories yet. Create your first one!
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         TAG VIEWS
    ═══════════════════════════════════════════ -->

    <record id="view_past_work_tag_list" model="ir.ui.view">
        <field name="name">past.work.tag.list</field>
        <field name="model">past.work.tag</field>
        <field name="arch" type="xml">
            <list string="Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_past_work_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">past.work.tag</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ═══════════════════════════════════════════
         PROJECT: FORM VIEW
    ═══════════════════════════════════════════ -->

    <record id="view_past_work_project_form" model="ir.ui.view">
        <field name="name">past.work.project.form</field>
        <field name="model">past.work.project</field>
        <field name="arch" type="xml">
            <form string="Past Work Project">
                <header>
                    <button name="action_publish"
                            string="Publish"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'published'"/>
                    <button name="action_unpublish"
                            string="Unpublish"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'published'"/>
                    <button name="action_archive_project"
                            string="Archive"
                            type="object"
                            invisible="state == 'archived'"/>
                    <button name="action_view_on_website"
                            string="View on Website"
                            type="object"
                            class="btn-info"
                            invisible="state != 'published'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_on_website"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-globe"
                                invisible="state != 'published'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">View Website</span>
                            </div>
                        </button>
                        <button class="oe_stat_button"
                                icon="fa-picture-o"
                                type="button">
                            <field name="image_count" widget="statinfo" string="Images"/>
                        </button>
                    </div>

                    <!-- Cover image widget on the left -->
                    <field name="cover_image"
                           widget="image"
                           class="oe_avatar oe_left"
                           options="{'preview_image': 'cover_image', 'size': [128, 128]}"/>

                    <div class="oe_title">
                        <label for="name" string="Project Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Brand Identity for Acme Corp"/>
                        </h1>
                        <field name="subtitle" placeholder="Short tagline shown on the card…"/>
                    </div>

                    <group>
                        <group string="Classification">
                            <field name="category_id"/>
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                            <field name="featured"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Project Details">
                            <field name="client_name"/>
                            <field name="timeline"/>
                            <field name="year"/>
                            <field name="services"/>
                            <field name="project_url" widget="url"/>
                            <field name="slug"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Project Overview" name="overview">
                            <field name="description" widget="html"
                                   placeholder="Write a full project overview here…"/>
                        </page>
                        <page string="Challenge &amp; Approach" name="challenge">
                            <group>
                                <field name="challenge" widget="html"
                                       placeholder="Describe the challenge faced…"
                                       colspan="2"/>
                                <field name="approach" widget="html"
                                       placeholder="Describe the approach / solution…"
                                       colspan="2"/>
                            </group>
                        </page>
                        <page string="Gallery Images" name="gallery">
                            <field name="image_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="image" widget="image"
                                           options="{'size': [64, 64]}"/>
                                    <field name="caption"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         PROJECT: LIST VIEW
    ═══════════════════════════════════════════ -->

    <record id="view_past_work_project_list" model="ir.ui.view">
        <field name="name">past.work.project.list</field>
        <field name="model">past.work.project</field>
        <field name="arch" type="xml">
            <list string="Past Work Projects"
                  decoration-muted="state == 'archived'"
                  decoration-success="state == 'published'"
                  decoration-info="state == 'draft'">
                <field name="sequence" widget="handle"/>
                <field name="cover_image" widget="image"
                       options="{'size': [40, 40]}" string=" "/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="client_name"/>
                <field name="year"/>
                <field name="featured" widget="boolean_toggle"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'published'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'archived'"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         PROJECT: KANBAN VIEW
    ═══════════════════════════════════════════ -->

    <record id="view_past_work_project_kanban" model="ir.ui.view">
        <field name="name">past.work.project.kanban</field>
        <field name="model">past.work.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id"
                    class="o_kanban_small_column"
                    quick_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="cover_image"/>
                <field name="subtitle"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="client_name"/>
                <field name="year"/>
                <field name="featured"/>
                <templates>
                    <t t-name="card">
                        <div class="past-work-kanban-card">
                            <!-- Cover Image -->
                            <t t-if="record.cover_image.raw_value">
                                <div class="past-work-kanban-img">
                                    <img t-att-src="'/web/image/past.work.project/' + record.id.raw_value + '/cover_image/300x200'"
                                         class="img-fluid"
                                         alt="Project Cover"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="past-work-kanban-img past-work-kanban-img-placeholder">
                                    <i class="fa fa-image fa-3x text-muted"/>
                                </div>
                            </t>

                            <div class="past-work-kanban-body p-2">
                                <!-- Status badge -->
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span t-if="record.state.raw_value == 'published'"
                                          class="badge bg-success text-white">Published</span>
                                    <span t-elif="record.state.raw_value == 'draft'"
                                          class="badge bg-warning text-dark">Draft</span>
                                    <span t-else=""
                                          class="badge bg-secondary text-white">Archived</span>
                                    <span t-if="record.featured.raw_value"
                                          class="badge bg-primary text-white ms-1">
                                        <i class="fa fa-star"/> Featured
                                    </span>
                                </div>

                                <strong class="d-block mt-1">
                                    <t t-esc="record.name.value"/>
                                </strong>
                                <small class="text-muted" t-if="record.subtitle.raw_value">
                                    <t t-esc="record.subtitle.value"/>
                                </small>

                                <div class="mt-1 small text-muted" t-if="record.client_name.raw_value">
                                    <i class="fa fa-user me-1"/>
                                    <t t-esc="record.client_name.value"/>
                                </div>
                                <div class="small text-muted" t-if="record.year.raw_value">
                                    <i class="fa fa-calendar me-1"/>
                                    <t t-esc="record.year.value"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         PROJECT: SEARCH VIEW
    ═══════════════════════════════════════════ -->

    <record id="view_past_work_project_search" model="ir.ui.view">
        <field name="name">past.work.project.search</field>
        <field name="model">past.work.project</field>
        <field name="arch" type="xml">
            <search string="Search Past Work">
                <field name="name" string="Project Name"/>
                <field name="client_name"/>
                <field name="category_id"/>
                <field name="year"/>
                <separator/>
                <filter string="Published" name="published"
                        domain="[('state','=','published')]"/>
                <filter string="Draft" name="draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Featured" name="featured"
                        domain="[('featured','=',True)]"/>
                <separator/>
                <filter string="Group by Category" name="group_category"
                        context="{'group_by': 'category_id'}"/>
                <filter string="Group by Year" name="group_year"
                        context="{'group_by': 'year'}"/>
                <filter string="Group by Status" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         PROJECT: ACTION
    ═══════════════════════════════════════════ -->

    <record id="action_past_work_project" model="ir.actions.act_window">
        <field name="name">Past Work Projects</field>
        <field name="res_model">past.work.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_published': 0}</field>
        <field name="search_view_id" ref="view_past_work_project_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No projects yet — add your first past work!
            </p>
            <p>
                Create a project, fill in client details, upload images,
                then publish it to show it on your website.
            </p>
        </field>
    </record>

    <record id="action_past_work_project_published" model="ir.actions.act_window">
        <field name="name">Published Projects</field>
        <field name="res_model">past.work.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('state', '=', 'published')]</field>
        <field name="search_view_id" ref="view_past_work_project_search"/>
    </record>

</odoo>
