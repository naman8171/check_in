<odoo>
    <record id="view_past_work_tree" model="ir.ui.view">
        <field name="name">past.work.tree</field>
        <field name="model">past.work</field>
        <field name="arch" type="xml">
            <list string="Past Works" default_order="sequence,completion_date desc">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="client_name"/>
                <field name="completion_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_past_work_form" model="ir.ui.view">
        <field name="name">past.work.form</field>
        <field name="model">past.work</field>
        <field name="arch" type="xml">
            <form string="Past Work">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Project title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="client_name"/>
                            <field name="completion_date"/>
                            <field name="project_url" widget="url"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_past_work_kanban" model="ir.ui.view">
        <field name="name">past.work.kanban</field>
        <field name="model">past.work</field>
        <field name="arch" type="xml">
            <kanban class="o_past_work_kanban" default_order="sequence,completion_date desc">
                <field name="name"/>
                <field name="category_id"/>
                <field name="description_short"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card o_past_work_card">
                            <div class="o_past_work_card_image">
                                <img t-if="record.image.raw_value" t-att-src="kanban_image('past.work', 'image', record.id.raw_value)" t-att-alt="record.name.value"/>
                                <div t-else="" class="o_past_work_placeholder">No Image</div>
                            </div>
                            <div class="o_past_work_card_body">
                                <h4><field name="name"/></h4>
                                <p class="o_past_work_category"><field name="category_id"/></p>
                                <p class="o_past_work_description"><field name="description_short"/></p>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_past_work" model="ir.actions.act_window">
        <field name="name">Past Works</field>
        <field name="res_model">past.work</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first past work entry.</p>
        </field>
    </record>
</odoo>
