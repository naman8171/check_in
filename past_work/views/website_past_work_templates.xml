<odoo>
    <template id="past_work_page" name="Past Work Listing">
        <t t-call="website.layout">
            <section id="portfolio" class="portfolio section pw-portfolio-section">
                <div class="container section-title">
                    <h2>Past Work</h2>
                    <p>A curated list of completed projects and case studies.</p>
                </div>

                <div class="container">
                    <form method="get" action="/past-work" class="pw-filter-form mb-4">
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-4 col-md-6">
                                <label class="form-label" for="pw_category">Category</label>
                                <select id="pw_category" name="category" class="form-select">
                                    <option value="">All Projects</option>
                                    <t t-foreach="categories" t-as="category">
                                        <option t-att-value="category.id" t-att-selected="'selected' if selected_category == category.id else None">
                                            <t t-esc="category.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-lg-6 col-md-6">
                                <label class="form-label" for="pw_search">Search</label>
                                <input id="pw_search" type="search" name="search" class="form-control" placeholder="Search title, client, description..." t-att-value="search"/>
                            </div>
                            <div class="col-lg-2 col-md-12 d-grid">
                                <button type="submit" class="btn btn-dark">Filter</button>
                            </div>
                        </div>
                    </form>

                    <div class="row gy-4 portfolio-grid">
                        <t t-foreach="works" t-as="work">
                            <div class="col-lg-4 col-md-6 portfolio-item">
                                <div class="portfolio-card h-100">
                                    <div class="portfolio-image">
                                        <img t-if="work.image" t-att-src="'/web/image/past.work/%s/image' % work.id" class="img-fluid" t-att-alt="work.name" loading="lazy"/>
                                        <img t-else="" src="/past_work/static/src/img/past_work_placeholder.svg" class="img-fluid" alt="No image" loading="lazy"/>
                                        <div class="portfolio-overlay">
                                            <div class="portfolio-actions">
                                                <a t-att-href="'/past-work/%s' % work.id" class="details-link" title="View Project Details">
                                                    <span aria-hidden="true">↗</span>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="portfolio-content">
                                        <span class="category"><t t-esc="work.category_id.name"/></span>
                                        <h3><a t-att-href="'/past-work/%s' % work.id"><t t-esc="work.name"/></a></h3>
                                        <p><t t-esc="work.description_short or 'No description provided.'"/></p>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                    <div class="alert alert-info mt-4" t-if="not works">
                        No past work items match your current filters.
                    </div>
                </div>
            </section>
        </t>
    </template>

    <template id="past_work_detail_page" name="Past Work Detail">
        <t t-call="website.layout">
            <section class="portfolio-details section pw-portfolio-detail">
                <div class="container section-title">
                    <h2><t t-esc="work.name"/></h2>
                    <p><a href="/past-work">← Back to all works</a></p>
                </div>
                <div class="container" data-aos="fade-up" data-aos-delay="100">
                    <div class="row gy-4">
                        <div class="col-lg-8">
                            <img t-if="work.image" t-att-src="'/web/image/past.work/%s/image' % work.id" class="img-fluid rounded" t-att-alt="work.name"/>
                            <img t-else="" src="/past_work/static/src/img/past_work_placeholder.svg" class="img-fluid rounded" alt="No image"/>
                            <div class="mt-4" t-out="work.description or ''"/>
                        </div>
                        <div class="col-lg-4">
                            <div class="portfolio-info">
                                <h3>Project Information</h3>
                                <ul>
                                    <li><strong>Category</strong>: <span t-esc="work.category_id.name"/></li>
                                    <li t-if="work.client_name"><strong>Client</strong>: <span t-esc="work.client_name"/></li>
                                    <li t-if="work.completion_date"><strong>Completion Date</strong>: <span t-esc="work.completion_date"/></li>
                                    <li t-if="work.project_url"><strong>Project URL</strong>: <a t-att-href="work.project_url" target="_blank" rel="noopener">Visit Project</a></li>
                                    <li t-if="work.tag_ids"><strong>Tags</strong>: <span t-esc="', '.join(work.tag_ids.mapped('name'))"/></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>
</odoo>
