<odoo>
    <record id="module_category_past_work" model="ir.module.category">
        <field name="name">Past Work</field>
        <field name="description">Manage past work portfolio records.</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_past_work_user" model="res.groups">
        <field name="name">Past Work User</field>
        <field name="category_id" ref="past_work.module_category_past_work"/>
    </record>

    <record id="group_past_work_manager" model="res.groups">
        <field name="name">Past Work Manager</field>
        <field name="category_id" ref="past_work.module_category_past_work"/>
        <field name="implied_ids" eval="[(4, ref('past_work.group_past_work_user'))]"/>
    </record>
</odoo>
