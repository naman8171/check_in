<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_past_work_catalog" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.past.work.catalog</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='website']" position="inside">
                <block title="Past Work Catalog" name="past_work_catalog_block">
                    <setting string="Spreadsheet CSV URL"
                             help="Paste the public CSV export URL used for the past work catalogue.">
                        <field name="past_work_spreadsheet_url" placeholder="https://docs.google.com/.../export?format=csv"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
