<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_stripe_fee" model="ir.ui.view">
        <field name="name">account.move.form.stripe.fee</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="stripe_fee_amount" readonly="1" invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>
</odoo>
