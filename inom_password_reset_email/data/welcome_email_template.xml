<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <record id="welcome_email_view" model="ir.ui.view">
        <field name="name">EY Welcome Email</field>
        <field name="type">qweb</field>
        <field name="arch" type="xml">
            <div
                style="margin:0; padding:0; background-color:#f6f6fa; font-family:Arial, Helvetica, sans-serif; color:#2e2e38;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                    style="width:100%; background-color:#f6f6fa; margin:0; padding:24px 0;">
                    <tr>
                        <td align="center" style="padding:0 12px;">
                            <table role="presentation" width="640" cellspacing="0" cellpadding="0"
                                border="0"
                                style="width:100%; max-width:640px; background-color:#ffffff; border-collapse:collapse; border-top:8px solid #ffe600;">
                                <tr>
                                    <td style="padding:32px 40px 18px 40px;">
                                        <img
                                            t-att-src="'%s/inom_password_reset_email/static/src/img/ey_logo.svg' % object.get_base_url()"
                                            alt="EY" width="96"
                                            style="display:block; width:96px; max-width:96px; height:auto; border:0; outline:none; text-decoration:none;" />
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:0 40px 8px 40px;">
                                        <h1
                                            style="margin:0; font-size:28px; line-height:36px; font-weight:700; color:#2e2e38;">Welcome
                                            to EY</h1>
                                    </td>
                                </tr>
                                <tr>
                                    <td
                                        style="padding:12px 40px 0 40px; font-size:16px; line-height:24px; color:#2e2e38;">
                                        <p style="margin:0 0 16px 0;">Hello <t
                                                t-out="object.name or 'there'" />,</p>
                                        <p style="margin:0 0 16px 0;">An EY account has been created
                                            for you<t t-if="object.login"> with login <strong
                                                    t-out="object.login" /></t>.</p>
                                        <p style="margin:0 0 24px 0;">Use the secure button below to
                                            set your password and activate your account. For your
                                            protection, this link is personal to you and should not
                                            be shared.</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="left" style="padding:0 40px 28px 40px;">
                                        <a t-att-href="object.partner_id._get_signup_url()"
                                            style="display:inline-block; background-color:#ffe600; color:#2e2e38; text-decoration:none; font-weight:700; font-size:16px; line-height:20px; padding:14px 24px; border-radius:0; border:1px solid #ffe600;">Set
                                            your password</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td
                                        style="padding:0 40px 24px 40px; font-size:14px; line-height:21px; color:#4d4d5c;">
                                        <p style="margin:0 0 12px 0;">If the button does not work,
                                            copy and paste this secure link into your browser:</p>
                                        <p style="margin:0; word-break:break-all;">
                                            <a t-att-href="object.partner_id._get_signup_url()"
                                                style="color:#2e2e38; text-decoration:underline;">
                                                <t t-out="object.partner_id._get_signup_url()" />
                                            </a>
                                        </p>
                                    </td>
                                </tr>
                                <tr>
                                    <td
                                        style="padding:0 40px 32px 40px; font-size:14px; line-height:21px; color:#4d4d5c;">
                                        <p style="margin:0 0 12px 0;">If you were not expecting this
                                            account, you can safely ignore this email.</p>
                                        <p style="margin:0;">Thank you,<br />EY Support Team</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td
                                        style="background-color:#2e2e38; padding:24px 40px; color:#ffffff; font-size:12px; line-height:18px;">
                                        <p style="margin:0 0 8px 0; font-weight:700; color:#ffe600;">
                                            EY</p>
                                        <p style="margin:0; color:#ffffff;">This message was sent by
                                            EY for account activation purposes. Please do not share
                                            this link with anyone.</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </div>
        </field>
    </record>
</odoo>
