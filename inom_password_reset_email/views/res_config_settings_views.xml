<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inom" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.inom.password.reset</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="EY Notifications" name="inom_password_reset_email">
                    <block title="Custom Notification Templates">
                        <setting string="Use Custom Branded Email Templates"
                                 help="Turn on to send EY-branded notifications. Only the templates selected below will actually be emailed; everything else stays disabled.">
                            <field name="enable_custom_email_templates"/>
                            <div class="content-group" invisible="not enable_custom_email_templates">
                                <field name="active_notification_template_ids"
                                       widget="many2many_tags"
                                       placeholder="Select which templates should send emails..."/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
