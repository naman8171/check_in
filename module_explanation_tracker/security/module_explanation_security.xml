<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="group_module_explanation_manager" model="res.groups">
        <field name="name">Module Explanation Manager</field>
        <field name="category_ids" eval="[(4, ref('base.module_category_human_resources'))]"/>
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>

    <record id="module_explanation_activity_rule_employee_own" model="ir.rule">
        <field name="name">Module Explanation - Employee Own Records</field>
        <field name="model_id" ref="model_module_explanation_activity"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="module_explanation_activity_rule_manager" model="ir.rule">
        <field name="name">Module Explanation - Manager Full Access</field>
        <field name="model_id" ref="model_module_explanation_activity"/>
        <field name="groups" eval="[(4, ref('module_explanation_tracker.group_module_explanation_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
