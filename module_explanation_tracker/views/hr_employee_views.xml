<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_employee_form_module_explanation_metrics" model="ir.ui.view">
        <field name="name">hr.employee.form.module.explanation.metrics</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_employee_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Module Performance" groups="module_explanation_tracker.group_module_explanation_manager">
                    <group col="4">
                        <field name="explained_module_count" readonly="1"/>
                        <field name="avg_explanation_rating" readonly="1"/>
                        <field name="total_explanation_hours" readonly="1"/>
                        <field name="performance_score" readonly="1"/>
                    </group>
                    <field name="explanation_activity_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="module_name"/>
                            <field name="state"/>
                            <field name="actual_duration_hours"/>
                            <field name="rating"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
