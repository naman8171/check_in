<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_module_explanation_activity_list" model="ir.ui.view">
        <field name="name">module.explanation.activity.list</field>
        <field name="model">module.explanation.activity</field>
        <field name="arch" type="xml">
            <list string="Module Explanation Activities" decoration-success="state == 'done'" decoration-warning="state == 'submitted'">
                <field name="name"/>
                <field name="module_name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <field name="assigned_date"/>
                <field name="due_date"/>
                <field name="actual_duration_hours"/>
                <field name="rating"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_module_explanation_activity_form" model="ir.ui.view">
        <field name="name">module.explanation.activity.form</field>
        <field name="model">module.explanation.activity</field>
        <field name="arch" type="xml">
            <form string="Module Explanation Activity">
                <header>
                    <button name="action_assign" string="Assign" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_start" string="Start" type="object" invisible="state not in ('assigned', 'draft')"/>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state not in ('in_progress', 'assigned')"/>
                    <button name="action_mark_done" string="Mark Evaluated" type="object" class="btn-primary" invisible="state != 'submitted'" groups="module_explanation_tracker.group_module_explanation_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('cancel', 'done')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state not in ('cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,assigned,in_progress,submitted,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="module_name"/>
                            <field name="employee_id"/>
                            <field name="manager_id"/>
                        </group>
                        <group>
                            <field name="assigned_date"/>
                            <field name="due_date"/>
                            <field name="explanation_date" readonly="state in ('draft', 'assigned')"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Explanation Details">
                            <group>
                                <field name="module_description"/>
                                <field name="employee_notes" placeholder="Employee can add explanation summary and outcomes"/>
                            </group>
                        </page>
                        <page string="Effort &amp; Rating">
                            <group>
                                <group>
                                    <field name="planned_duration_hours"/>
                                    <field name="actual_duration_hours"/>
                                    <field name="effort_score" readonly="1"/>
                                </group>
                                <group>
                                    <field name="rating"/>
                                    <field name="manager_feedback" placeholder="Performance feedback by manager"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_module_explanation_activity_search" model="ir.ui.view">
        <field name="name">module.explanation.activity.search</field>
        <field name="model">module.explanation.activity</field>
        <field name="arch" type="xml">
            <search string="Module Explanation Activities">
                <field name="name"/>
                <field name="module_name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <filter string="My Activities" name="my_activities" domain="[('user_id', '=', uid)]"/>
                <filter string="Evaluated" name="evaluated" domain="[('state', '=', 'done')]"/>
                <filter string="Pending" name="pending" domain="[('state', 'in', ('assigned', 'in_progress', 'submitted'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by':'employee_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by':'state'}"/>
                    <filter name="group_rating" string="Rating" context="{'group_by':'rating'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_module_explanation_activity_pivot" model="ir.ui.view">
        <field name="name">module.explanation.activity.pivot</field>
        <field name="model">module.explanation.activity</field>
        <field name="arch" type="xml">
            <pivot string="Explanation Analytics">
                <field name="employee_id" type="row"/>
                <field name="state" type="col"/>
                <field name="id" type="measure" string="Total Modules"/>
                <field name="actual_duration_hours" type="measure"/>
                <field name="rating_value" type="measure" string="Average Rating"/>
                <field name="effort_score" type="measure" string="Average Effort Score"/>
            </pivot>
        </field>
    </record>

    <record id="view_module_explanation_activity_graph" model="ir.ui.view">
        <field name="name">module.explanation.activity.graph</field>
        <field name="model">module.explanation.activity</field>
        <field name="arch" type="xml">
            <graph string="Explanation Performance" type="bar">
                <field name="employee_id"/>
                <field name="id" type="measure" string="Modules"/>
                <field name="rating_value" type="measure"/>
                <field name="actual_duration_hours" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_module_explanation_activity" model="ir.actions.act_window">
        <field name="name">Module Explanation Activities</field>
        <field name="res_model">module.explanation.activity</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_module_explanation_activity_search"/>
        <field name="context">{'search_default_my_activities': 1}</field>
    </record>

    <record id="action_module_explanation_dashboard" model="ir.actions.act_window">
        <field name="name">Module Explanation Dashboard</field>
        <field name="res_model">module.explanation.activity</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="domain">[('state', '=', 'done')]</field>
        <field name="context">{'group_by':'employee_id'}</field>
    </record>
</odoo>
