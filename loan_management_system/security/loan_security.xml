<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_loan_internal_user" model="res.groups">
        <field name="name">Loan Internal Applicant</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_loan_user" model="res.groups">
        <field name="name">Loan User</field>
    </record>

    <record id="group_loan_manager" model="res.groups">
        <field name="name">Loan Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_loan_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]" />
    </record>

    <record id="rule_internal_user_loan_own" model="ir.rule">
        <field name="name">Internal Applicant - Own Loan Requests</field>
        <field name="model_id" ref="model_loan_loan"/>
        <field name="groups" eval="[(4, ref('group_loan_internal_user'))]"/>
        <field name="domain_force">[('request_source', '=', 'internal'), ('internal_user_id', '=', user.id)]</field>
    </record>
</odoo>
