<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loan_loan_tree" model="ir.ui.view">
        <field name="name">loan.loan.tree</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="application_date"/>
                <field name="principal_amount"/>
                <field name="total_amount"/>
                <field name="outstanding_amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_loan_loan_form" model="ir.ui.view">
        <field name="name">loan.loan.form</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight" invisible="state != 'submitted'" groups="loan_management_system.group_loan_manager"/>
                    <button name="action_disburse" type="object" string="Disburse" class="oe_highlight" invisible="state != 'approved'" groups="loan_management_system.group_loan_manager"/>
                    <button name="action_close" type="object" string="Close" invisible="state != 'disbursed'" groups="loan_management_system.group_loan_manager"/>
                    <button name="action_reject" type="object" string="Reject" invisible="state in ('rejected','closed')" groups="loan_management_system.group_loan_manager"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,disbursed,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" icon="fa-list" name="action_view_installments">
                            <field name="installment_count" string="Installments" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_generate_schedule" icon="fa-calendar" invisible="state not in ('draft','submitted','approved')">
                            <span class="o_stat_text">Generate Schedule</span>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="loan_type"/>
                            <field name="application_date"/>
                            <field name="first_due_date"/>
                        </group>
                        <group>
                            <field name="principal_amount"/>
                            <field name="interest_rate"/>
                            <field name="term_months"/>
                            <field name="processing_fee"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="total_interest" readonly="1"/>
                            <field name="total_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="paid_amount" readonly="1"/>
                            <field name="outstanding_amount" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Installments">
                            <field name="installment_ids" readonly="state in ('closed','rejected')">
                                <tree editable="bottom">
                                    <field name="sequence" readonly="1"/>
                                    <field name="due_date"/>
                                    <field name="principal_amount"/>
                                    <field name="interest_amount"/>
                                    <field name="amount"/>
                                    <field name="balance_amount"/>
                                    <field name="state"/>
                                    <field name="paid_on"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_loan_loan_search" model="ir.ui.view">
        <field name="name">loan.loan.search</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="filter_disbursed" string="Disbursed" domain="[('state', '=', 'disbursed')]"/>
                <filter name="filter_closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Customer" name="group_partner" domain="[]" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_loan_loan" model="ir.actions.act_window">
        <field name="name">Loans</field>
        <field name="res_model">loan.loan</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_loan_loan_search"/>
        <field name="context">{'search_default_filter_draft': 1}</field>
    </record>
</odoo>
