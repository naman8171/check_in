<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_loan_config_list" model="ir.ui.view">
        <field name="name">loan.config.list</field>
        <field name="model">loan.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="interest_rate" />
                <field name="processing_fee" />
                <field name="penalty_rate" />
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_loan_config_form" model="ir.ui.view">
        <field name="name">loan.config.form</field>
        <field name="model">loan.config</field>
        <field name="arch" type="xml">
            <form string="Loan Configuration">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="interest_rate" />
                        <field name="processing_fee" />
                        <field name="penalty_rate" />
                        <field name="active" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_loan_config" model="ir.actions.act_window">
        <field name="name">Loan Configuration</field>
        <field name="res_model">loan.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>