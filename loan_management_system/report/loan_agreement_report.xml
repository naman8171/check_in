<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_loan_agreement" model="ir.actions.report">
        <field name="name">Loan Agreement</field>
        <field name="model">loan.loan</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">loan_management_system.report_loan_agreement_template</field>
        <field name="report_file">loan_management_system.report_loan_agreement_template</field>
        <field name="print_report_name">'Loan Agreement - %s' % (object.name)</field>
    </record>

    <template id="report_loan_agreement_template">
        <t t-call="web.external_layout">
            <div class="page">
                <h2 style="text-align:center;">Loan Agreement</h2>
                <p><strong>Loan Number:</strong> <span t-field="o.name"/></p>
                <p><strong>Borrower:</strong> <span t-field="o.partner_id.name"/></p>
                <p><strong>Loan Type:</strong> <span t-field="o.loan_type_id.name"/></p>
                <p><strong>Principal:</strong> <span t-field="o.principal_amount"/></p>
                <p><strong>Interest Rate:</strong> <span t-field="o.interest_rate"/>%</p>
                <p><strong>Term:</strong> <span t-field="o.term_months"/> months</p>
                <p><strong>First Due Date:</strong> <span t-field="o.first_due_date"/></p>
                <hr/>
                <div t-if="o.agreement_html" t-out="o.agreement_html"/>
                <div t-if="not o.agreement_html">
                    <p>The borrower agrees to repay the loan according to the approved repayment schedule.</p>
                </div>
                <br/><br/>
                <p>Borrower Signature: _________________________</p>
                <p>Date: _________________________</p>
            </div>
        </t>
    </template>
</odoo>
