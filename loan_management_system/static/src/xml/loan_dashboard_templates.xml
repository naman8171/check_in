<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="loan_management_system.LoanDashboardClientAction">
        <div class="o_loan_dashboard_main" t-if="!state.loading and state.data">
            <div class="o_ld_filters_top">
                <select t-on-change="(ev) => this.onFilterChange(ev, 'user_id')"><option value="">All Users</option><option t-foreach="state.data.filters.users" t-as="user_item" t-key="user_item.id" t-att-value="user_item.id" t-esc="user_item.name"/></select>
                <select t-on-change="(ev) => this.onFilterChange(ev, 'borrower_id')"><option value="">All Borrowers</option><option t-foreach="state.data.filters.borrowers" t-as="borrower_item" t-key="borrower_item.id" t-att-value="borrower_item.id" t-esc="borrower_item.name"/></select>
                <select t-on-change="(ev) => this.onFilterChange(ev, 'loan_type_id')"><option value="">All Loan Types</option><option t-foreach="state.data.filters.loan_types" t-as="loan_type_item" t-key="loan_type_item.id" t-att-value="loan_type_item.id" t-esc="loan_type_item.name"/></select>
                <select t-on-change="(ev) => this.onFilterChange(ev, 'date_range')"><option value="lifetime">Lifetime</option><option value="this_month">This Month</option><option value="last_3_month">Last 3 Months</option><option value="this_year">This Year</option></select>
                <button class="btn btn-primary" t-on-click="printDashboard">Print</button>
            </div>

            <div class="o_ld_grid_3">
                <div class="o_ld_card_panel" id="panel_monthly_trend">
                    <div class="o_ld_panel_head"><h4>Loan Request 3 Month Trends</h4><button class="o_ld_icon_btn" t-on-click="() => this.downloadPanel('panel_monthly_trend')">⬇</button></div>
                    <div class="o_ld_bar_chart">
                        <div class="o_ld_hbar" t-foreach="state.data.monthly_trend" t-as="month_row" t-key="month_row.label"><label t-esc="month_row.label"/><div class="o_ld_hbar_track"><div class="o_ld_hbar_fill" t-att-style="this.monthlyWidth(month_row.amount)"/></div><span t-esc="this.amount(month_row.amount)"/></div>
                    </div>
                </div>

                <div class="o_ld_card_panel" id="panel_principal_interest">
                    <div class="o_ld_panel_head"><h4>Principal vs. Interest</h4><button class="o_ld_icon_btn" t-on-click="() => this.downloadPanel('panel_principal_interest')">⬇</button></div>
                    <div class="o_ld_total">Total EMI Amount</div>
                    <div class="o_ld_total_amt" t-esc="this.amount(state.data.kpis.repayment_amount + state.data.kpis.interest_amount)"/>
                    <div class="o_ld_stacked"/>
                    <ul class="o_ld_legend_list"><li><i class="dot orange"/> Interest Amount <b t-esc="this.amount(state.data.kpis.interest_amount)"/></li><li><i class="dot brown"/> Principle Amount <b t-esc="this.amount(state.data.kpis.disbursed_amount)"/></li></ul>
                </div>

                <div class="o_ld_card_panel" id="panel_paid_unpaid">
                    <div class="o_ld_panel_head"><h4>Paid vs. Unpaid Installments</h4><button class="o_ld_icon_btn" t-on-click="() => this.downloadPanel('panel_paid_unpaid')">⬇</button></div>
                    <div class="o_ld_donut" t-att-style="this.paidUnpaidStyle()"><div class="o_ld_donut_hole"/></div>
                    <div class="o_ld_legend_inline"><span><i class="dot green"/> Paid Installment</span><span><i class="dot red"/> Due Installment</span></div>
                </div>
            </div>

            <div class="o_ld_grid_2">
                <div class="o_ld_card_panel" id="panel_stage_status">
                    <div class="o_ld_panel_head"><h4>Stage-Wise Loan Status Overview</h4><button class="o_ld_icon_btn" t-on-click="() => this.downloadPanel('panel_stage_status')">⬇</button></div>
                    <div class="o_ld_vbars"><div class="o_ld_vbar" t-foreach="this.stageRows()" t-as="stage_row" t-key="stage_row.label"><div class="o_ld_vbar_fill" t-att-style="this.stageWidth(stage_row.count)"/><small t-esc="stage_row.label"/></div></div>
                </div>

                <div class="o_ld_card_panel" id="panel_loan_type">
                    <div class="o_ld_panel_head"><h4>Loan Volume by Loan Type</h4><button class="o_ld_icon_btn" t-on-click="() => this.downloadPanel('panel_loan_type')">⬇</button></div>
                    <div class="o_ld_donut o_ld_clickable" t-att-style="this.loanTypeStyle()"><div class="o_ld_donut_hole"/></div>
                    <ul class="o_ld_legend_list">
                        <li t-if="state.data.loan_type_volume[0]"><i class="dot green"/> <a href="#" t-on-click.prevent="() => this.openLoanTypeRecords(state.data.loan_type_volume[0].id)"><span t-esc="state.data.loan_type_volume[0].name"/></a> <b t-esc="this.amount(state.data.loan_type_volume[0].amount)"/></li>
                        <li t-if="state.data.loan_type_volume[1]"><i class="dot red"/> <a href="#" t-on-click.prevent="() => this.openLoanTypeRecords(state.data.loan_type_volume[1].id)"><span t-esc="state.data.loan_type_volume[1].name"/></a> <b t-esc="this.amount(state.data.loan_type_volume[1].amount)"/></li>
                    </ul>
                </div>
            </div>

            <div class="o_ld_grid_2">
                <div class="o_ld_card_panel">
                    <div class="o_ld_panel_head"><h4>Top Partners: Loan Amount</h4><button class="o_ld_icon_btn" t-on-click="() => this.downloadPanel('panel_top_partners')">⬇</button></div>
                    <div class="o_ld_subfilter"><label>Top Partner</label><select class="o_small_select" t-on-change="(ev) => this.onFilterChange(ev, 'top_limit')"><option value="5">5</option><option value="10">10</option><option value="20">20</option></select></div>
                    <div class="o_ld_desc">Top partner which has loan amount high</div>
                    <ul class="o_ld_rank_list" id="panel_top_partners"><li t-foreach="state.data.top_partners" t-as="partner_row" t-key="partner_row.name"><span t-esc="partner_row.name"/><b t-esc="this.amount(partner_row.amount)"/></li></ul>
                </div>

                <div class="o_ld_card_panel">
                    <div class="o_ld_panel_head"><h4>Top Partners: Loan Installments Status</h4><button class="o_ld_icon_btn" t-on-click="() => this.downloadPanel('panel_top_installments')">⬇</button></div>
                    <div class="o_ld_subfilter"><label>Top Installment</label><select class="o_small_select" t-on-change="(ev) => this.onFilterChange(ev, 'top_limit')"><option value="5">5</option><option value="10">10</option><option value="20">20</option></select></div>
                    <div id="panel_top_installments" class="o_ld_install_status"><div class="o_paid">Paid: <t t-esc="state.data.kpis.paid_installment"/></div><div class="o_unpaid">Unpaid: <t t-esc="state.data.kpis.unpaid_installment"/></div></div>
                </div>
            </div>

            <div class="o_ld_grid_2">
                <div class="o_ld_card_panel">
                    <div class="o_ld_panel_head"><h4>Upcoming Installment</h4><span>Duration:
                        <select class="o_small_select" t-on-change="(ev) => this.onFilterChange(ev, 'upcoming_duration')"><option value="30">Next 30 Days</option><option value="90">Next 90 Days</option><option value="365">Next 365 Days</option></select>
                    </span></div>
                    <table class="table table-sm o_ld_table"><thead><tr><th>Name</th><th>Loan Id</th><th>Client</th><th>Amount</th><th>Date</th><th/></tr></thead><tbody><tr t-foreach="this.upcomingInstallments()" t-as="up_item" t-key="up_item.id"><td t-esc="up_item.name"/><td t-esc="up_item.loan"/><td t-esc="up_item.borrower"/><td t-esc="this.amount(up_item.amount_due)"/><td t-esc="up_item.due_date"/><td><button class="btn btn-sm btn-secondary">View</button></td></tr></tbody></table>
                </div>

                <div class="o_ld_card_panel">
                    <div class="o_ld_panel_head"><h4>Overdue Installment</h4><span>Specific Records</span></div>
                    <table class="table table-sm o_ld_table"><thead><tr><th>Name</th><th>Loan Id</th><th>Client</th><th>Amount</th><th>Date</th><th/></tr></thead><tbody><tr t-foreach="this.overdueInstallments()" t-as="od_item" t-key="od_item.id"><td t-esc="od_item.name"/><td t-esc="od_item.loan"/><td t-esc="od_item.borrower"/><td t-esc="this.amount(od_item.amount_due)"/><td t-esc="od_item.due_date"/><td><button class="btn btn-sm btn-secondary">View</button></td></tr></tbody></table>
                </div>
            </div>

            <div class="o_ld_pager"><button class="btn btn-outline-secondary" t-on-click="prevPage" t-att-disabled="!state.data.has_prev">See previous records</button><span>Page <t t-esc="state.page"/> of <t t-esc="this.totalPages()"/></span><button class="btn btn-outline-secondary" t-on-click="nextPage" t-att-disabled="!state.data.has_next">See next records</button></div>
        </div>
        <div t-else="" class="o_loan_dashboard_main o_ld_loading">Loading dashboard...</div>
    </t>
</templates>
